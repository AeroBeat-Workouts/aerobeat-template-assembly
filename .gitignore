# Godot 4+ specific ignores
.godot/
.import/
export_presets.cfg

# Imported translations (automatically generated from CSV files)
*.translation

# Mono-specific ignores
.mono/
data_*/
mono_crash.*.json

# System specific
.DS_Store
Thumbs.db

# GodotEnv-generated assembly dependencies
addons/*
!addons/.editorconfig
.addons/

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
